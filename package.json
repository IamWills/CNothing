{
  "name": "keyservice",
  "version": "0.1.0",
  "private": true,
  "description": "Envelope-encrypted key custody service for agent-safe provider secret issuance",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun run src/index.ts",
    "migrate": "bun run src/db/migrate.ts",
    "generate-secrets": "bun run src/scripts/generate-secrets.ts",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx eslint src --ext .ts"
  },
  "dependencies": {
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "bun-types": "^1.3.7",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
