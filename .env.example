# Network
PORT=3021

# PostgreSQL connection string used by keyservice migrations and runtime
DATABASE_URL=postgresql://username:password@127.0.0.1:5432/keyservice

# 32-byte master key encoded as base64 or base64url
# Generate with: bun run generate-secrets
KEYSERVICE_MASTER_KEY=

# RSA private key path used by keyservice to decrypt auth/data/query envelopes
# Generate with: bun run generate-secrets
KEYSERVICE_AUTHAI_PRIVATE_KEY_PATH=.local-keys/authai-private-key.pem

# Optional public key path. If omitted, keyservice derives the public key from the private key.
KEYSERVICE_AUTHAI_PUBLIC_KEY_PATH=.local-keys/authai-public-key.pem

# One-time challenge TTL in seconds
KEYSERVICE_CHALLENGE_TTL_SECONDS=300

# Reserved for future management/admin interfaces. Not required for current public authai/kv protocol.
KEYSERVICE_BEARER_TOKEN=
