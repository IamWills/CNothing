{
  "name": "cnothing",
  "version": "0.1.4",
  "description": "CNothing AuthAI + Encrypted KV server and SDK for AI-safe secret workflows",
  "type": "module",
  "main": "./dist/library.js",
  "types": "./dist/library.d.ts",
  "exports": {
    ".": {
      "types": "./dist/library.d.ts",
      "import": "./dist/library.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.CN.MD"
  ],
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun run src/index.ts",
    "migrate": "bun run src/db/migrate.ts",
    "generate-secrets": "bun run src/scripts/generate-secrets.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "bun run build",
    "console:dev": "cd console && bun run dev",
    "console:build": "cd console && bun run build",
    "console:start": "cd console && bun run start",
    "console:typecheck": "cd console && bun run typecheck",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx eslint src --ext .ts"
  },
  "dependencies": {
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "bun-types": "^1.3.7",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.0"
  }
}
